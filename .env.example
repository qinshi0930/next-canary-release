# ============================================
# 环境变量模板 — 复制为 .env.production 并填写真实值
# 注意：此文件不应提交到版本控制系统
# ============================================

# ============================================
# Node 环境
# ============================================
NODE_ENV=production

# ============================================
# Infra 配置
# ============================================
REDIS_PASSWORD=redis123
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=master_db
POSTGRES_USER=xingye

# ============================================
# Redis 配置（生产环境使用容器内部网络）
# ============================================
REDIS_URL=redis://:redis123@redis:6379/0

# ============================================
# GitHub App 配置（用于访问私有仓库）
# ============================================
APP_ID=
APP_PEM_KEY_BASE64=
APP_INSTALLATION_ID=

# ============================================
# GitHub OAuth 配置（用于用户登录）
# 注意：使用 AUTH_GITHUB_ 前缀避免与 GitHub Actions 的系统变量冲突
# 如果不需要 GitHub 登录功能，可以留空
# ============================================
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# ============================================
# SMTP 邮件配置（联系表单）
# ============================================
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# ============================================
# SUPABASE 配置
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# Database 连接（Supabase 或本地 Postgres）
# 优先级：此 DATABASE_URL 覆盖 Infra 中的 Postgres 连接
# ============================================
DATABASE_URL=postgresql://xingye:postgres123@postgres:5432/master_db

# ============================================
# Better Auth 配置
# ============================================
BETTER_AUTH_URL=
BETTER_AUTH_SECRET=